{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=HomeBites;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Debug"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "super-secret-key-that-is-at-least-thirty-two-characters-long",
    "Issuer": "HomeBitesIssuer",
    "Audience": "HomeBitesAudience"
  },
  "AzureBlobStorage": {
    "ConnectionString": "UseDevelopmentStorage=true",
    "ContainerName": "homebites-uploads"
  }
}